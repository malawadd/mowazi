ENVIRONMENT=local
WORKER_SHARED_SECRET=replace-with-the-same-secret-used-by-convex
CONVEX_WORKER_URL=https://your-deployment.convex.site/worker
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=moeazi-analysis
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@timescaledb:5432/moeazi
REDIS_URL=redis://redis:6379/0
OTEL_EXPORTER_OTLP_ENDPOINT=

OPENAI_API_KEY=
OPENAI_SPECIALIST_MODEL=gpt-5.4-mini
OPENAI_SYNTHESIS_MODEL=gpt-5.6-sol
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_SPECIALIST_MODEL=deepseek-v4-flash
DEEPSEEK_SYNTHESIS_MODEL=deepseek-v4-pro
PROVIDER_MAX_CONCURRENCY=40
PROVIDER_MODE=balanced
DEEPSEEK_THINKING_ENABLED=false
SPECIALIST_MAX_OUTPUT_TOKENS=700
SYNTHESIS_MAX_OUTPUT_TOKENS=1200
EVIDENCE_MAX_ITEMS=8
EVIDENCE_MAX_CHARS_PER_ITEM=700
# Used only by the opt-in legacy polling profile. Temporal schedules use Manual Guard.
SCHEDULED_ANALYSIS_ENABLED=false
AGENT_DEV_CONTROLS_ENABLED=true
AGENT_MANUAL_GUARD_DEFAULT=true
AGENT_LITE_MODE_DEFAULT=true
DEV_STARTER_CREDITS=100
DEV_LITE_ACCOUNT_RUNS_PER_DAY=4
DEV_LITE_GLOBAL_RUNS_PER_DAY=8
DEV_LITE_PROVIDER_BUDGET_USD=0.10

QUICKNODE_STREAM_URL=
CRYPTOPANIC_API_KEY=
X_BEARER_TOKEN=
UNISWAP_API_KEY=
UNISWAP_API_URL=https://trade-api.gateway.uniswap.org/v1

# Public read-only venue routing. Ostium requires an Arbitrum RPC for SDK price reads.
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz/info
LIGHTER_API_URL=https://mainnet.zklighter.elliot.ai
ORDERLY_API_URL=https://api.orderly.org
OSTIUM_RPC_URL=
EXECUTION_SIDECAR_URL=http://execution-sidecar:8300
ROUTING_TIMEOUT_SECONDS=8
ROUTING_PREVIEW_CACHE_SECONDS=10
ROUTING_MARKET_CACHE_SECONDS=300

# Keep false until every named venue has sandbox coverage and a funded mainnet canary.
LIVE_EXECUTION_ENABLED=false
EXECUTION_GATEWAY_URL=http://execution-gateway:8200
CERTIFIED_VENUES=
# Local base64 AES key only. Production uses a cloud KMS implementation.
MASTER_KEY=
