# Moeazi local app environment
# Fill this file and move the values into `.env.local` for Next.js local development.

# Convex client connection
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Particle Auth keys from https://dashboard.particle.network/
NEXT_PUBLIC_PROJECT_ID=your-particle-project-id
NEXT_PUBLIC_CLIENT_KEY=your-particle-client-key
NEXT_PUBLIC_APP_ID=your-particle-app-id
NEXT_PUBLIC_APP_URL=http://localhost:3000
PARTICLE_PROJECT_SERVER_KEY=your-particle-server-key

# Magic embedded wallet for native EIP-7702 mode
NEXT_PUBLIC_MAGIC_API_KEY=your-magic-api-key
NEXT_PUBLIC_MAGIC_DELEGATION_CHAIN_ID=42161
NEXT_PUBLIC_MAGIC_RPC_URL=https://your-arbitrum-rpc-url

# Convex deployment environment variables
# Set these in the Convex dashboard or with `npx convex env set`.
PARTICLE_CONVEX_JWT_ISSUER=http://localhost:3000
PARTICLE_CONVEX_JWKS_URL=http://localhost:3000/api/auth/jwks
PARTICLE_CONVEX_JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----"
PARTICLE_CONVEX_JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\nreplace-me\n-----END PUBLIC KEY-----"
PARTICLE_CONVEX_JWT_KID=particle-convex
WALLET_MASTER_KEY=replace-with-a-long-random-secret
WORKER_SHARED_SECRET=replace-with-a-different-long-random-secret
ARBITRUM_RPC_URL=https://your-arbitrum-rpc-url
MAINNET_VENUE_SETUP_ENABLED=false
LIVE_EXECUTION_ENABLED=false
CERTIFIED_VENUES=

# Optional aliases / overrides used by some modules
# Legacy migration reads only; not required for active strategy execution.
OPTIMISM_RPC_URL=
QUICKNODE_HTTP=
UNISWAP_API_KEY=
UNISWAP_API_URL=https://trade-api.gateway.uniswap.org/v1
UNISWAP_ARBITRUM_TARGETS=
AGENT_API_URL=http://127.0.0.1:8100
BYOK_ENABLED=true
AGENT_LAB_ENABLED=true

# Read-only venue discovery and quote routing
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz/info
LIGHTER_API_URL=https://mainnet.zklighter.elliot.ai
ORDERLY_API_URL=https://api.orderly.org
OSTIUM_RPC_URL=https://your-arbitrum-rpc-url

# External Python supervisor
# Point this at your Convex HTTP action endpoint for `/worker`.
CONVEX_WORKER_URL=https://your-deployment.convex.site/worker
QUICKNODE_WSS=wss://your-optimism-rpc-websocket

# Legacy single-wallet bot only. These are not required for the managed Moeazi app.
PRIVATE_KEY=
HL_PRIVATE_KEY=
HL_WALLET_ADDRESS=
LP_WALLET_ADDRESS=
